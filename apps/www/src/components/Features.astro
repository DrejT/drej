<span class="block whitespace-pre-wrap break-words text-sm min-h-[1.5em]"> </span>
<span class="block whitespace-pre-wrap break-words text-sm"><span class="tok-var">sb</span><span class="tok-punct">.</span><span class="tok-fn">forEach</span><span class="tok-punct">(</span></span>
