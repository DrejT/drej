---
---

<section class="hero">
  <div class="inner">
    <h1 class="heading">The <span class="accent">RLM</span> agent orchestration framework.</h1>
    <p class="subhead">
      Spawn a sandbox, let an agent decompose the task, and fork children that
      inherit its exact state — every exec ledgered, every checkpoint&nbsp;resumable.
    </p>
    <p class="meta">Open source · Apache 2.0 licensed.</p>

    <div class="ctas">
      <a href="https://docs.drej.dev" class="btn-primary">Read the docs</a>
      <a href="https://github.com/DrejT/drej" class="btn-secondary">GitHub →</a>
      <button type="button" class="btn-copy" data-copy="bunx drejx init">
        <span class="copy-icon" aria-hidden="true">⧉</span>
        <span class="copy-label">bunx drejx init</span>
      </button>
    </div>
  </div>
</section>

<section class="hero-demo">
  <div class="demo-inner">
    <div class="code-wrapper">
      <div class="code-header">
        <span class="status-dot" aria-hidden="true"></span>
        <span class="filename">index.ts</span>
        <span class="node-tag">sandbox · 0.5 vCPU · 256Mi</span>
      </div>
      <pre
        class="code-block"
      ><code><span class="line"><span class="kw">const</span> <span class="var">root</span> <span class="op">=</span> <span class="kw">await</span> <span class="var">Agent</span><span class="p">.</span><span class="fn">load</span><span class="p">(</span><span class="str">"planner.json"</span><span class="p">);</span></span>
<span class="line empty"> </span>
<span class="line"><span class="kw">const</span> <span class="p">[</span><span class="var">a</span><span class="p">,</span> <span class="var">b</span><span class="p">]</span> <span class="op">=</span> <span class="kw">await</span> <span class="var">Promise</span><span class="p">.</span><span class="fn">all</span><span class="p">([</span></span>
<span class="line">  <span class="var">root</span><span class="p">.</span><span class="fn">spawn</span><span class="p">(</span><span class="str">"worker.json"</span><span class="p">),</span></span>
<span class="line">  <span class="var">root</span><span class="p">.</span><span class="fn">spawn</span><span class="p">(</span><span class="str">"worker.json"</span><span class="p">),</span></span>
<span class="line"><span class="p">]);</span></span>
<span class="line empty"> </span>
<span class="line"><span class="kw">await</span> <span class="var">a</span><span class="p">.</span><span class="fn">prompt</span><span class="p">(</span><span class="str">"Review src/api"</span><span class="p">);</span></span>
<span class="line"><span class="kw">await</span> <span class="var">b</span><span class="p">.</span><span class="fn">prompt</span><span class="p">(</span><span class="str">"Review src/db"</span><span class="p">);</span></span>
</code></pre>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 96px;
    padding-bottom: 3rem;
    display: flex;
    align-items: center;
  }

  .inner {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .heading {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    max-width: 16ch;
    margin-bottom: 1rem;
  }

  .heading .accent {
    color: var(--color-accent);
  }

  .subhead {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--color-muted);
    max-width: 46ch;
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-muted);
    opacity: 0.8;
    margin-bottom: 2rem;
  }

  /* CTAs */
  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    justify-content: center;
  }

  .btn-primary,
  .btn-secondary,
  .btn-copy {
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--radius-btn);
    transition:
      background 0.15s,
      border-color 0.15s,
      color 0.15s;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.35rem;
    background: var(--color-fg);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-accent);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.35rem;
    border: 1px solid var(--color-border);
    color: var(--color-fg);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .btn-copy {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.1rem;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    font-family: var(--font-mono);
    cursor: pointer;
  }

  .btn-copy:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .copy-icon {
    font-size: 0.9rem;
  }

  /* Full-bleed demo band */
  .hero-demo {
    width: 100%;
    padding: 4rem 2rem 5rem;
    background:
      radial-gradient(46% 42% at 50% -6%, oklch(0.62 0.22 259 / 0.65), transparent 72%),
      radial-gradient(75% 65% at 50% 8%, oklch(0.38 0.17 259 / 0.5), transparent 76%),
      oklch(0.07 0 0);
  }

  .demo-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  /* Code wrapper */
  .code-wrapper {
    border: 1px solid var(--color-code-border);
    border-radius: 10px;
    overflow: hidden;
    width: 100%;
    text-align: left;
    box-shadow: 0 24px 60px oklch(0 0 0 / 0.45);
  }

  /* Header chrome */
  .code-header {
    background: var(--color-code-header-bg);
    padding: 0 1rem;
    height: 34px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--color-code-border);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-code-accent);
    box-shadow: 0 0 0 0 oklch(0.72 0.13 259 / 0.45);
    animation: hero-pulse 2.2s ease-out infinite;
  }

  @keyframes hero-pulse {
    0% {
      box-shadow: 0 0 0 0 oklch(0.72 0.13 259 / 0.45);
    }
    70% {
      box-shadow: 0 0 0 6px oklch(0.72 0.13 259 / 0);
    }
    100% {
      box-shadow: 0 0 0 0 oklch(0.72 0.13 259 / 0);
    }
  }

  .filename {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-code-muted);
    letter-spacing: 0.01em;
  }

  .node-tag {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-code-muted);
    border: 1px solid var(--color-code-border);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
  }

  /* Code body */
  .code-block {
    background: var(--color-code-bg);
    margin: 0;
    padding: 1.5rem 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.7;
    /* The <pre> tag's UA default is white-space: pre, which renders the literal
       newlines between the .line spans below as their own blank line breaks —
       stacking on top of each span's own display:block break and doubling every
       line's height. Each .line already sets its own white-space: pre-wrap, so
       the parent doesn't need to preserve whitespace too. */
    white-space: normal;
    counter-reset: line;
  }

  code {
    font-family: inherit;
  }

  .line {
    display: block;
    padding: 0 1.5rem 0 0;
    counter-increment: line;
    opacity: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .line::before {
    content: counter(line);
    display: inline-block;
    width: 1.75rem;
    margin-right: 1.5rem;
    padding-left: 1rem;
    text-align: right;
    color: var(--color-code-muted);
    font-size: 0.78rem;
    user-select: none;
  }

  .line.empty {
    min-height: 1.7em;
  }

  /* Syntax "highlighting" — monochrome, accent reserved for strings only */
  .kw   { color: var(--color-code-fg); }
  .var  { color: var(--color-code-dim); }
  .fn   { color: var(--color-code-fg); }
  .str  { color: var(--color-code-accent); }
  .prop { color: var(--color-code-dim); }
  .op   { color: var(--color-code-muted); }
  .p    { color: var(--color-code-muted); }

  @media (max-width: 640px) {
    .ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .btn-primary,
    .btn-secondary,
    .btn-copy {
      justify-content: center;
    }
  }
</style>

<script>
  import { createTimeline, stagger } from "animejs";

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReduced) {
    document.querySelectorAll<HTMLElement>(".code-block .line").forEach((el) => {
      el.style.opacity = "1";
    });
  } else {
    createTimeline({ defaults: { ease: "outQuad" } }).add(".code-block .line", {
      opacity: [0, 1],
      translateY: [6, 0],
      delay: stagger(45),
      duration: 300,
    });
  }

  const copyBtn = document.querySelector<HTMLButtonElement>(".btn-copy");
  copyBtn?.addEventListener("click", async () => {
    const text = copyBtn.dataset.copy ?? "";
    const label = copyBtn.querySelector<HTMLElement>(".copy-label");
    if (!label) return;
    try {
      await navigator.clipboard.writeText(text);
      const original = label.textContent;
      label.textContent = "Copied!";
      setTimeout(() => {
        label.textContent = original;
      }, 1500);
    } catch {
      // clipboard API unavailable — no-op, the command is still visible to copy by hand
    }
  });
</script>
