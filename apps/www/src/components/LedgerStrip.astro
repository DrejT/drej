---
const events = [
  "sandbox_created",
  "exec_start",
  "exec_complete",
  "checkpoint_created",
  "sandbox_closed",
];

// Duplicate so the loop is seamless: translate by -50% = one copy's width
const items = [...events, ...events];
---

<div class="strip" aria-hidden="true">
  <div class="strip-inner">
    {
      items.map((ev) => (
        <>
          <span class="event">{ev}</span>
          <span class="sep">·</span>
        </>
      ))
    }
  </div>
</div>

<style>
  .strip {
    width: 100%;
    background: var(--color-strip-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
    padding: 0.85rem 0;
  }

  .strip-inner {
    display: flex;
    align-items: center;
    white-space: nowrap;
    width: max-content;
  }

  .event {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-fg);
    padding: 0 0.8rem;
  }

  .sep {
    color: #d1d5db;
    font-size: 0.78rem;
  }
</style>

<script>
  import anime from "animejs";

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReduced) {
    anime({
      targets: ".strip-inner",
      translateX: ["0%", "-50%"],
      duration: 22000,
      easing: "linear",
      loop: true,
    });
  }
</script>
