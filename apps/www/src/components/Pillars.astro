---
const pillars = [
  { keyword: "Spawn.", desc: "A sandbox in one call." },
  { keyword: "Exec.", desc: "Commands, code, files — live stdout." },
  { keyword: "Resume.", desc: "Checkpoint and replay from any point." },
];
---

<section class="pillars">
  <div class="inner">
    {
      pillars.map((p) => (
        <div class="pillar">
          <span class="keyword">{p.keyword}</span>
          <span class="desc">{p.desc}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  .pillars {
    padding: 6rem 2rem;
  }

  .inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .pillar {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    opacity: 0;
  }

  .keyword {
    font-family: var(--font-mono);
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    min-width: 9ch;
    flex-shrink: 0;
  }

  .desc {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  @media (max-width: 540px) {
    .pillar {
      flex-direction: column;
      gap: 0.3rem;
    }

    .keyword {
      min-width: unset;
    }
  }
</style>

<script>
  import anime from "animejs";

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReduced) {
    document.querySelectorAll<HTMLElement>(".pillar").forEach((el) => {
      el.style.opacity = "1";
    });
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0]?.isIntersecting) {
          anime({
            targets: ".pillar",
            opacity: [0, 1],
            translateX: [-18, 0],
            delay: anime.stagger(120),
            duration: 420,
            easing: "easeOutQuad",
          });
          observer.disconnect();
        }
      },
      { threshold: 0.2 },
    );

    const section = document.querySelector(".pillars");
    if (section) observer.observe(section);
  }
</script>
