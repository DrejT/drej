{
  "$schema": "https://registry.drej.dev/spec/agent.json",
  "name": "master-agent",
  "title": "Master Agent",
  "description": "A Pi agent with the drejx CLI + Pi extension installed, demonstrating an agent orchestrating its own child agent sessions via typed drejx_* tools instead of raw osb bash commands.",
  "author": "drej",
  "cli": "pi",
  "provider": "nvidia",
  "model": "nvidia/nemotron-3-super-120b-a12b",
  "packages": ["nodejs_22"],
  "env": {
    "NVIDIA_API_KEY": "${NVIDIA_API_KEY}",
    "MASTER_AGENT_OPENSANDBOX_DOMAIN": "${MASTER_AGENT_OPENSANDBOX_DOMAIN}"
  },
  "resources": { "cpu": "1000m", "memory": "2Gi" },
  "setup": [
    { "name": "Install drejx", "run": "npm install -g drejx" },
    {
      "name": "Enable drejx Pi extension",
      "run": "mkdir -p .pi/extensions && cp \"$(npm root -g)/drejx/pi-extension/drejx.ts\" .pi/extensions/drejx.ts"
    },
    {
      "name": "Configure drejx",
      "run": "mkdir -p agents && printf '{\"serverUrl\":\"http://%s\",\"useServerProxy\":false,\"apiKey\":\"\",\"adapterPath\":\"./.drej/ledger.db\",\"agentsDir\":\"./agents\",\"defaults\":{\"resources\":{\"cpu\":\"500m\",\"memory\":\"1Gi\"}}}' \"$MASTER_AGENT_OPENSANDBOX_DOMAIN\" > drej.config.json"
    },
    {
      "name": "Add a child spec for drejx_run to launch",
      "run": "printf '{\"name\":\"hello-agent\",\"cli\":\"pi\",\"provider\":\"nvidia\",\"model\":\"nvidia/nemotron-3-super-120b-a12b\",\"env\":{\"NVIDIA_API_KEY\":\"%s\"},\"resources\":{\"cpu\":\"500m\",\"memory\":\"1Gi\"}}' \"$NVIDIA_API_KEY\" > agents/hello-agent.json"
    }
  ]
}
