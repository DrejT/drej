{
  "$schema": "https://registry.drej.dev/spec/agent.json",
  "name": "workspace-agent",
  "title": "Workspace Agent",
  "description": "Demonstrates setup steps: a small Node.js project is created before the snapshot.",
  "author": "drej",
  "cli": "pi",
  "provider": "nvidia",
  "model": "nvidia/nemotron-3-super-120b-a12b:free",
  "packages": ["python3"],
  "env": {
    "NVIDIA_API_KEY": "${NVIDIA_API_KEY}"
  },
  "resources": { "cpu": "1000m", "memory": "2Gi" },
  "setup": [
    { "name": "Create workspace", "run": "mkdir -p /workspace" },
    {
      "name": "Write package.json",
      "run": "printf '{\"name\":\"app\",\"version\":\"1.0.0\"}' > package.json",
      "cwd": "/workspace"
    },
    {
      "name": "Write index.js",
      "run": "printf 'console.log(\"workspace ready — setup baked into snapshot\")' > index.js",
      "cwd": "/workspace"
    },
    { "name": "Verify", "run": "node index.js", "cwd": "/workspace" }
  ]
}
