{
  "name": "drej",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/opensandbox",
    "packages/sdks/typescript",
    "packages/workflow",
    "packages/adapters/postgres",
    "packages/adapters/sqlite",
    "packages/adapters/otel",
    "packages/adapters/flue",
    "packages/agent",
    "packages/cli",
    "examples/*",
    "tests/integration",
    "apps/docs",
    "apps/www",
    "apps/registry",
    "apps/sandbox"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "build": "bun scripts/workspace-run.ts build",
    "typecheck": "bun scripts/workspace-run.ts typecheck",
    "test": "bun scripts/workspace-run.ts test",
    "test:integration": "bun run --cwd tests/integration test",
    "lint": "oxlint packages examples",
    "lint:fix": "oxlint --fix packages examples",
    "format": "oxfmt packages examples apps '!**/CHANGELOG.md'",
    "format:check": "oxfmt --check packages examples apps '!**/CHANGELOG.md'",
    "release:publish": "bun scripts/resolve-workspace-protocol.ts && bun changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.71.0"
  },
  "overrides": {
    "vite": "7.3.6"
  }
}
