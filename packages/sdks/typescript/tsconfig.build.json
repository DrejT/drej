{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM"],
    "types": ["bun-types"],
    "ignoreDeprecations": "5.0"
  },
  "include": ["src"]
}
